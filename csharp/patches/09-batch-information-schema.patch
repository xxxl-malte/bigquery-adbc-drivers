 csharp/src/BigQueryConnection.cs | 165 ++++++++++++++++++++++++++-----
 1 file changed, 140 insertions(+), 25 deletions(-)

--- a/csharp/src/BigQueryConnection.cs
+++ b/csharp/src/BigQueryConnection.cs
