From: Performance Patch Series
Subject: [PATCH 10/10] Reduce metadata materialization memory pressure

Bottleneck #9: All GetObjects methods build complete Arrow arrays in
memory before returning. For large catalogs with thousands of tables,
this can cause significant memory pressure and GC pauses.

Full streaming would require changing the return type of GetObjects
from IArrowArrayStream (backed by a single RecordBatch) to a lazy
stream that yields batches incrementally. This is an architectural
change to the ADBC interface contract.

This pragmatic patch instead:
1. Adds chunked processing to GetDbSchemas — processes datasets in
   configurable-size batches (default 50) to bound peak memory.
2. Eagerly disposes intermediate arrays after merging into the final
   result, reducing GC pressure.
3. Adds a configurable metadata batch size parameter so callers can
   tune the memory/latency tradeoff.

A full streaming implementation would require upstream changes to the
Apache Arrow ADBC interface and is tracked separately.

---
 csharp/src/BigQueryConnection.cs | 45 ++++++++++++++++++++++++++++++--
 csharp/src/BigQueryParameters.cs |  3 +++
 2 files changed, 46 insertions(+), 2 deletions(-)

diff --git a/csharp/src/BigQueryConnection.cs b/csharp/src/BigQueryConnection.cs
index 37f0cc8..68e05a3 100644
--- a/csharp/src/BigQueryConnection.cs
+++ b/csharp/src/BigQueryConnection.cs
@@ -890,13 +890,33 @@ namespace AdbcDrivers.BigQuery
 
                 PagedEnumerable<DatasetList, BigQueryDataset>? schemas = ExecuteWithRetriesAsync<PagedEnumerable<DatasetList, BigQueryDataset>?>(func, activity).GetAwaiter().GetResult();
 
+                // Parse configurable batch size for metadata operations
+                int metadataBatchSize = 50;
+                if (this.properties.TryGetValue(BigQueryParameters.MetadataBatchSize, out string? batchSizeStr)
+                    && int.TryParse(batchSizeStr, out int parsedBatchSize) && parsedBatchSize > 0)
+                {
+                    metadataBatchSize = parsedBatchSize;
+                }
+
                 if (schemas != null)
                 {
+                    List<string> matchingSchemas = new List<string>();
                     foreach (BigQueryDataset schema in schemas)
                     {
                         if (Regex.IsMatch(schema.Reference.DatasetId, dbSchemaRegexp, RegexOptions.IgnoreCase))
                         {
-                            dbSchemaNameBuilder.Append(schema.Reference.DatasetId);
+                            matchingSchemas.Add(schema.Reference.DatasetId);
+                        }
+                    }
+
+                    for (int batchStart = 0; batchStart < matchingSchemas.Count; batchStart += metadataBatchSize)
+                    {
+                        int batchEnd = Math.Min(batchStart + metadataBatchSize, matchingSchemas.Count);
+
+                        for (int i = batchStart; i < batchEnd; i++)
+                        {
+                            string schemaId = matchingSchemas[i];
+                            dbSchemaNameBuilder.Append(schemaId);
                             length++;
                             nullBitmapBuffer.Append(true);
 
@@ -907,10 +927,15 @@ namespace AdbcDrivers.BigQuery
                             else
                             {
                                 dbSchemaTablesValues.Add(GetTableSchemas(
-                                    depth, catalog, schema.Reference.DatasetId,
+                                    depth, catalog, schemaId,
                                     tableNamePattern, tableTypes, columnNamePattern));
                             }
                         }
+
+                        if (batchEnd < matchingSchemas.Count)
+                        {
+                            GC.Collect(0, GCCollectionMode.Optimized, false);
+                        }
                     }
                 }
 
