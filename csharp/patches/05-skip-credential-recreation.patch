From: Performance Patch Series
Subject: [PATCH 05/10] Lightweight client refresh in UpdateClientToken

Bottleneck #4: UpdateClientToken() calls Open(), which re-reads and
re-validates ALL connection properties (projectId, billingProjectId,
includePublicProjectId, clientTimeout, defaultLocation, etc.) even
though none of these change during a token refresh. This adds CPU
overhead, dictionary lookups, and tracing spans on every refresh.

This patch replaces the full Open() call in UpdateClientToken() with a
lightweight RefreshClient() method that:
1. Calls SetCredential() — MUST happen to pick up new tokens
2. Rebuilds the BigQueryClient using already-parsed settings stored
   on the connection object (DefaultClientLocation, ClientTimeout, etc.)
3. Preserves the current project ID (from patch 04)

The heavy property re-parsing in Open() is only needed on initial
connection; subsequent credential refreshes reuse the parsed values.

---
 csharp/src/BigQueryConnection.cs | 40 +++++++++++++++++++++++++++-----
 1 file changed, 34 insertions(+), 6 deletions(-)

diff --git a/csharp/src/BigQueryConnection.cs b/csharp/src/BigQueryConnection.cs
index 6179fb2..be3377e 100644
--- a/csharp/src/BigQueryConnection.cs
+++ b/csharp/src/BigQueryConnection.cs
@@ -686,11 +686,42 @@ namespace AdbcDrivers.BigQuery
         /// </summary>
         internal void UpdateClientToken()
         {
-            // Preserve the detected project ID across credential refreshes
-            string? currentProjectId = Client?.ProjectId;
-            if (string.IsNullOrEmpty(currentProjectId) || currentProjectId == BigQueryConstants.DetectProjectId)
-                currentProjectId = null; // let Open() resolve it from properties
-            Client = Open(currentProjectId);
+            RefreshClient();
+        }
+
+        /// <summary>
+        /// Lightweight client refresh — reuses already-parsed settings, only refreshes credentials.
+        /// </summary>
+        private void RefreshClient()
+        {
+            this.TraceActivity(activity =>
+            {
+                SetCredential();
+
+                string? projectId = Client?.ProjectId;
+                if (string.IsNullOrEmpty(projectId) || projectId == BigQueryConstants.DetectProjectId)
+                    this.properties.TryGetValue(BigQueryParameters.ProjectId, out projectId);
+
+                string? billingProjectId = null;
+                this.properties.TryGetValue(BigQueryParameters.BillingProjectId, out billingProjectId);
+
+                BigQueryClientBuilder builder = new BigQueryClientBuilder()
+                {
+                    QuotaProject = billingProjectId,
+                    GoogleCredential = Credential,
+                    ProjectId = !string.IsNullOrEmpty(billingProjectId) ? billingProjectId : projectId
+                };
+
+                if (!string.IsNullOrEmpty(DefaultClientLocation))
+                    builder.DefaultLocation = DefaultClientLocation;
+
+                BigQueryClient client = builder.Build();
+
+                if (ClientTimeout.HasValue)
+                    client.Service.HttpClient.Timeout = ClientTimeout.Value;
+
+                Client = client;
+            }, ClassName + "." + nameof(RefreshClient));
         }
 
         /// <summary>
