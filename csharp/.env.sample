# ---------------------------------------------------------------
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.
# ---------------------------------------------------------------

# Path (on host) to the GCP service account JSON key file.
# Used by integration-test and optionally by perf-test.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# Path (on host) to the integration test config JSON file.
# See test/Resources/bigqueryconfig.json for the template.
BIGQUERY_TEST_CONFIG_FILE=./secrets/bigqueryconfig.json

# Path (on host) to the performance test config JSON file.
# See perf/perfconfig.sample.json for the template.
BIGQUERY_PERF_CONFIG_FILE=./secrets/perfconfig.json
